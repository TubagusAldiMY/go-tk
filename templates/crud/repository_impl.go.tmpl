func (r *{{.EntityNameLC}}Repository) FindAll(ctx context.Context, page, pageSize int) ([]*entity.{{.EntityName}}, int64, error) {
	var items []*entity.{{.EntityName}}
	var total int64

	offset := (page - 1) * pageSize

	if err := r.db.WithContext(ctx).Model(&entity.{{.EntityName}}{}).Count(&total).Error; err != nil {
		return nil, 0, fmt.Errorf("count {{.EntityNamePL}}: %w", err)
	}

	if err := r.db.WithContext(ctx).Limit(pageSize).Offset(offset).Find(&items).Error; err != nil {
		r.log.Error("{{.EntityNameLC}}.FindAll failed", "error", err)
		return nil, 0, fmt.Errorf("find all {{.EntityNamePL}}: %w", err)
	}

