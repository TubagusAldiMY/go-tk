func (r *{{.EntityNameLC}}Repository) FindByID(ctx context.Context, id uint) (*entity.{{.EntityName}}, error) {
	var e entity.{{.EntityName}}
	result := r.db.WithContext(ctx).First(&e, id)
	if result.Error != nil {
		if errors.Is(result.Error, gorm.ErrRecordNotFound) {
			return nil, Err{{.EntityName}}NotFound
		}
		r.log.Error("{{.EntityNameLC}}.FindByID failed", "id", id, "error", result.Error)
		return nil, fmt.Errorf("find {{.EntityNameLC}} by id: %w", result.Error)
