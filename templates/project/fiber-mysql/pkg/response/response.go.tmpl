// Package response provides standard JSON response helpers for Gin handlers.
package response

import (
	"net/http"

	"github.com/gin-gonic/gin"
)

// Envelope is the standard API response wrapper.
type Envelope struct {
	Success bool   `json:"success"`
	Message string `json:"message,omitempty"`
	Data    any    `json:"data,omitempty"`
	Error   string `json:"error,omitempty"`
}

// OK sends 200 with data.
func OK(c *gin.Context, data any) {
	c.JSON(http.StatusOK, Envelope{Success: true, Data: data})
}

// Created sends 201 with data.
func Created(c *gin.Context, data any) {
	c.JSON(http.StatusCreated, Envelope{Success: true, Data: data})
}

// NoContent sends 204.
func NoContent(c *gin.Context) {
	c.Status(http.StatusNoContent)
}

// BadRequest sends 400 with error message.
func BadRequest(c *gin.Context, msg string) {
	c.JSON(http.StatusBadRequest, Envelope{Success: false, Error: msg})
}

// Unauthorized sends 401.
func Unauthorized(c *gin.Context, msg string) {
	if msg == "" {
		msg = "unauthorized"
	}
	c.JSON(http.StatusUnauthorized, Envelope{Success: false, Error: msg})
}

// Forbidden sends 403.
func Forbidden(c *gin.Context, msg string) {
	if msg == "" {
		msg = "forbidden"
	}
	c.JSON(http.StatusForbidden, Envelope{Success: false, Error: msg})
}

// NotFound sends 404.
func NotFound(c *gin.Context, msg string) {
	if msg == "" {
		msg = "resource not found"
	}
	c.JSON(http.StatusNotFound, Envelope{Success: false, Error: msg})
}

// Conflict sends 409.
func Conflict(c *gin.Context, msg string) {
	c.JSON(http.StatusConflict, Envelope{Success: false, Error: msg})
}

// UnprocessableEntity sends 422 with validation errors.
func UnprocessableEntity(c *gin.Context, err error) {
	c.JSON(http.StatusUnprocessableEntity, Envelope{
		Success: false,
		Error:   "validation failed",
		Data:    err.Error(),
	})
}

// InternalServerError sends 500.
func InternalServerError(c *gin.Context, msg string) {
	if msg == "" {
		msg = "internal server error"
	}
	c.JSON(http.StatusInternalServerError, Envelope{Success: false, Error: msg})
}
