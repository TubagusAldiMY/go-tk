# Application
APP_NAME={{.ProjectName}}
APP_ENV=development
PORT=8080
LOG_LEVEL=debug

# Database (MySQL DSN format)
DATABASE_DSN={{.ProjectName}}_user:secret@tcp(localhost:3306)/{{.ProjectName}}_db?charset=utf8mb4&parseTime=True&loc=Local
DB_USER={{.ProjectName}}_user
DB_PASSWORD=secret
DB_NAME={{.ProjectName}}_db
DB_PORT=3306

# JWT
JWT_SECRET=change-me-in-production-use-at-least-32-chars
JWT_EXPIRY=24h

# CORS
ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
