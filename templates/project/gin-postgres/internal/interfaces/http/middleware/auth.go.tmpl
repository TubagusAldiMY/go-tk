package middleware

import (
	"strings"
	"sync"
	"time"

	"github.com/gin-gonic/gin"
	"github.com/golang-jwt/jwt/v5"

	"{{.ModulePath}}/pkg/response"
)

// Claims holds the JWT payload.
type Claims struct {
	UserID uint   `json:"user_id"`
	Role   string `json:"role"`
	jwt.RegisteredClaims
}

// ── Account Lockout ───────────────────────────────────────────────────────────

const (
	maxFailedAttempts = 5
	lockoutDuration   = 15 * time.Minute
)

type lockEntry struct {
	failures  int
	lockedAt  time.Time
	locked    bool
}

var lockStore sync.Map // identifier (email/IP) → *lockEntry

// RecordFailedAttempt increments the failure counter for the given identifier.
// After maxFailedAttempts the account is locked for lockoutDuration.
func RecordFailedAttempt(identifier string) {
	actual, _ := lockStore.LoadOrStore(identifier, &lockEntry{})
	entry := actual.(*lockEntry)
	entry.failures++
	if entry.failures >= maxFailedAttempts {
		entry.locked = true
		entry.lockedAt = time.Now()
	}
}

// ResetFailedAttempts clears the lockout state for an identifier (call on successful login).
func ResetFailedAttempts(identifier string) {
	lockStore.Delete(identifier)
}

// IsLocked returns true if the identifier is currently locked out.
func IsLocked(identifier string) bool {
	val, ok := lockStore.Load(identifier)
	if !ok {
		return false
	}
	entry := val.(*lockEntry)
	if !entry.locked {
		return false
	}
	// Auto-expire lockout after lockoutDuration.
	if time.Since(entry.lockedAt) >= lockoutDuration {
		lockStore.Delete(identifier)
		return false
	}
	return true
}

// ── JWT Middleware ────────────────────────────────────────────────────────────

// JWTAuth validates the Bearer token in the Authorization header.
// On success it sets "user_id" and "role" in the Gin context.
func JWTAuth(secret string) gin.HandlerFunc {
	return func(c *gin.Context) {
		authHeader := c.GetHeader("Authorization")
		if authHeader == "" {
			response.Unauthorized(c, "missing authorization header")
			c.Abort()
			return
		}

		parts := strings.SplitN(authHeader, " ", 2)
		if len(parts) != 2 || !strings.EqualFold(parts[0], "bearer") {
			response.Unauthorized(c, "invalid authorization header format")
			c.Abort()
			return
		}

		tokenStr := parts[1]
		claims := &Claims{}

		token, err := jwt.ParseWithClaims(tokenStr, claims, func(t *jwt.Token) (any, error) {
			if _, ok := t.Method.(*jwt.SigningMethodHMAC); !ok {
				return nil, jwt.ErrSignatureInvalid
			}
			return []byte(secret), nil
		})
		if err != nil || !token.Valid {
			response.Unauthorized(c, "invalid or expired token")
			c.Abort()
			return
		}

		c.Set("user_id", claims.UserID)
		c.Set("role", claims.Role)
		c.Next()
	}
}
